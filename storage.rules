rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow anyone to read all files (user app needs to download/view PDFs and images)
    match /{allPaths=**} {
      allow read: if true;
    }

    // Allow write for everyone — admin panel uses custom token auth (not Firebase Auth)
    // The admin panel itself is password-protected, so only authorized admins
    // can access the upload features. Firebase Storage doesn't see the custom token.
    // This is safe because:
    // 1. Admin panel URL is not publicly known
    // 2. Admin panel requires login (custom token)
    // 3. All uploaded files are public anyway (PDFs, images for users)
    match /{allPaths=**} {
      allow write: if true;
    }
  }
}