rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow anyone to read all files (user app needs to download/view PDFs)
    match /{allPaths=**} {
      allow read: if true;
    }

    // Allow authenticated users to upload files (admin operations)
    match /{allPaths=**} {
      allow write: if request.auth != null;
    }
  }
}