# ============================================================
# ExamVault Environment Variables
# Copy this file to ".env" and fill in real values.
# NEVER commit the real .env file (it is gitignored).
# ============================================================

# ---- Razorpay (REQUIRED for payments/upgrade flow) ----
# Dashboard: https://dashboard.razorpay.com/app/keys
# Test keys start with "rzp_test_", live keys with "rzp_live_".
RAZORPAY_KEY_ID=rzp_test_REPLACE_ME
RAZORPAY_KEY_SECRET=REPLACE_ME
# Webhook secret from Razorpay dashboard -> Settings -> Webhooks
# (optional but recommended for payment.captured/failed/refund handling)
RAZORPAY_WEBHOOK_SECRET=

# ---- Firebase Admin SDK (REQUIRED for server-side writes) ----
# Project Settings -> Service Accounts -> generate new private key.
# These let the /api/payments/verify, /api/payments/webhook and
# /api/payments/subscription-status routes write to Firestore securely.
# Without them the app falls back to the client SDK (less secure).
FIREBASE_PROJECT_ID=examvault-7fba8
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@examvault-7fba8.iam.gserviceaccount.com
# Paste the full private_key, keeping the \n escape sequences intact.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n"
